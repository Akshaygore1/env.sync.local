#!/bin/bash
# env-sync-client: Fetch and sync secrets from peers using SSH (SCP)
# Usage: env-sync-client [options] [hostname]
# Options:
#   -a, --all              Sync from all discovered peers
#   -f, --force            Force sync even if local is newer
#   -q, --quiet            Quiet mode
#   --insecure-http        Use insecure HTTP instead of SCP (not recommended)
#   hostname               Specific hostname to sync from (optional)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

ALL_PEERS=false
FORCE=false
USE_HTTP=false
TARGET_HOST=""

# Security warning for HTTP mode
print_http_warning() {
    if [[ "${ENV_SYNC_QUIET:-}" != "true" ]]; then
        echo ""
        echo "╔════════════════════════════════════════════════════════════════════════════╗"
        echo "║  ⚠️  SECURITY WARNING: USING INSECURE HTTP MODE                          ║"
        echo "║                                                                            ║"
        echo "║  You are using the insecure HTTP sync mode. This exposes your secrets:     ║"
        echo "║  • Transmitted in PLAINTEXT over the network                               ║"
        echo "║  • Accessible to ANY device on your local network                          ║"
        echo "║  • No authentication or encryption                                         ║"
        echo "║                                                                            ║"
        echo "║  RECOMMENDED: Use SCP mode (default) which requires SSH key authentication ║"
        echo "║  To use SCP: Remove the --insecure-http flag                               ║"
        echo "║                                                                            ║"
        echo "║  Only use HTTP mode if:                                                    ║"
        echo "║  • SSH keys are not set up between machines                                ║"
        echo "║  • You are on a completely trusted isolated network                        ║"
        echo "║  • You are testing/development only                                        ║"
        echo "╚════════════════════════════════════════════════════════════════════════════╝"
        echo ""
    fi
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -a|--all)
            ALL_PEERS=true
            shift
            ;;
        -f|--force)
            FORCE=true
            shift
            ;;
        -q|--quiet)
            ENV_SYNC_QUIET=true
            shift
            ;;
        --insecure-http)
            USE_HTTP=true
            shift
            ;;
        -h|--help)
            echo "Usage: env-sync-client [options] [hostname]"
            echo ""
            echo "Syncs secrets from peers using SSH/SCP (secure) by default."
            echo ""
            echo "Options:"
            echo "  -a, --all              Sync from all discovered peers"
            echo "  -f, --force            Force sync even if local is newer"
            echo "  -q, --quiet            Quiet mode"
            echo "  --insecure-http        Use insecure HTTP instead of SCP (not recommended)"
            echo "  hostname               Specific hostname to sync from"
            echo ""
            echo "Examples:"
            echo "  env-sync-client                           # Sync from newest peer via SCP"
            echo "  env-sync-client hostname.local            # Sync from specific host via SCP"
            echo "  env-sync-client --insecure-http           # Sync using HTTP (INSECURE)"
            exit 0
            ;;
        -*)
            log "ERROR" "Unknown option: $1"
            exit 1
            ;;
        *)
            if [[ -z "$TARGET_HOST" ]]; then
                TARGET_HOST="$1"
            else
                log "ERROR" "Multiple hostnames specified"
                exit 1
            fi
            shift
            ;;
    esac
done

# Print warning if using HTTP
if $USE_HTTP; then
    print_http_warning
fi

# Function to test SSH connectivity
test_ssh() {
    local host="$1"
    # Use SSH with batch mode to avoid password prompts
    if ssh -n -o BatchMode=yes -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new "$host" "echo OK" >/dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# Function to fetch from a single host using SCP
fetch_via_scp() {
    local host="$1"
    local remote_path="${host}:${SECRETS_FILE}"
    local tmp_file=$(mktemp)
    
    log "INFO" "Fetching from $host via SCP..."
    
    # Fetch file with scp
    if ! scp -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new "$remote_path" "$tmp_file" </dev/null >/dev/null 2>&1; then
        log "WARN" "Failed to fetch from $host via SCP (SSH key may not be set up)"
        rm -f "$tmp_file"
        return 1
    fi
    
    # Validate fetched file
    if ! validate_secrets_file "$tmp_file"; then
        log "WARN" "Invalid secrets file from $host"
        rm -f "$tmp_file"
        return 1
    fi
    
    echo "$tmp_file"
}

# Function to fetch from a single host using HTTP (insecure)
fetch_via_http() {
    local host="$1"
    local url="http://${host}:${ENV_SYNC_PORT}/secrets.env"
    local tmp_file=$(mktemp)
    
    log "INFO" "Fetching from $host via HTTP (INSECURE)..."
    
    # Fetch file with curl
    if ! curl -fsSL --connect-timeout 5 --max-time 10 "$url" -o "$tmp_file" 2>/dev/null; then
        log "WARN" "Failed to fetch from $host via HTTP"
        rm -f "$tmp_file"
        return 1
    fi
    
    # Validate fetched file
    if ! validate_secrets_file "$tmp_file"; then
        log "WARN" "Invalid secrets file from $host"
        rm -f "$tmp_file"
        return 1
    fi
    
    echo "$tmp_file"
}

# Function to fetch from a single host (auto-selects method)
fetch_from_host() {
    local host="$1"
    
    if $USE_HTTP; then
        fetch_via_http "$host"
    else
        # Try SCP first, fail if SSH not available
        fetch_via_scp "$host"
    fi
}

# Function to decrypt file for comparison
decrypt_for_comparison() {
    local file="$1"
    local output_file="$2"
    
    if is_file_encrypted "$file"; then
        if can_decrypt_file "$file"; then
            decrypt_secrets_file "$file" "$output_file"
            return 0
        else
            log "WARN" "Cannot decrypt file - not in recipient list"
            return 1
        fi
    else
        # Not encrypted, just copy
        cp "$file" "$output_file"
        return 0
    fi
}

# Function to re-encrypt secrets after merge
reencrypt_secrets() {
    local plaintext_file="$1"
    local output_file="$2"
    
    # Get all recipients
    local recipients=($(get_all_known_recipients))
    
    if [[ ${#recipients[@]} -eq 0 ]]; then
        log "WARN" "No recipients found - keeping as plaintext"
        cp "$plaintext_file" "$output_file"
        return 0
    fi
    
    # Read content
    local content=$(cat "$plaintext_file")
    
    # Encrypt to all recipients
    local encrypted_content=$(encrypt_secrets_content "$content" "${recipients[@]}")
    
    if [[ -z "$encrypted_content" ]]; then
        log "ERROR" "Failed to encrypt secrets"
        return 1
    fi
    
    # Build recipients string
    local recipients_str=$(IFS=,; echo "${recipients[*]}")
    
    # Save encrypted file
    save_encrypted_secrets "$output_file" "$encrypted_content" "$recipients_str"
    
    return 0
}

# Re-encrypt local file if new recipients were added
maybe_reencrypt_local() {
    if [[ ! -f "$SECRETS_FILE" ]]; then
        return 0
    fi

    if ! is_file_encrypted "$SECRETS_FILE"; then
        return 0
    fi

    if ! can_decrypt_file "$SECRETS_FILE"; then
        return 0
    fi

    local temp_decrypted=$(mktemp)
    if ! decrypt_secrets_file "$SECRETS_FILE" "$temp_decrypted"; then
        rm -f "$temp_decrypted"
        return 1
    fi

    local plain_content
    plain_content=$(sed '/^[[:space:]]*#/d' "$temp_decrypted" | sed '/^[[:space:]]*$/d')
    if [[ -z "$plain_content" ]]; then
        rm -f "$temp_decrypted"
        return 0
    fi

    local recipients_in_file=$(get_recipients_from_file "$SECRETS_FILE")
    local missing=false

    local recipients_all=()
    while IFS= read -r recipient; do
        [[ -z "$recipient" ]] && continue
        recipients_all+=("$recipient")
    done < <(get_all_known_recipients)

    if [[ ${#recipients_all[@]} -eq 0 ]]; then
        return 0
    fi

    for recipient in "${recipients_all[@]}"; do
        if [[ "$recipients_in_file" != *"$recipient"* ]]; then
            missing=true
            break
        fi
    done

    if ! $missing; then
        rm -f "$temp_decrypted"
        return 0
    fi

    if reencrypt_secrets "$temp_decrypted" "$SECRETS_FILE"; then
        log "SUCCESS" "Re-encrypted local secrets with updated recipients"
    fi

    rm -f "$temp_decrypted"
}

# Function to sync from a specific host
sync_from_host() {
    local host="$1"
    
    # Fetch file
    local remote_file
    if ! remote_file=$(fetch_from_host "$host"); then
        return 1
    fi
    
    # Check if remote file is encrypted and if we can decrypt it
    if is_file_encrypted "$remote_file"; then
        if ! can_decrypt_file "$remote_file"; then
            log "ERROR" "Cannot sync from $host - file is encrypted and we're not a recipient"
            log "INFO" "Run 'env-sync key request-access --trigger $host' to request access"
            rm -f "$remote_file"
            return 1
        fi
    fi
    
    # Check if local file exists
    if [[ ! -f "$SECRETS_FILE" ]]; then
        log "INFO" "No local secrets file found, copying from $host"
        
        # If remote is encrypted, we should re-encrypt to all known recipients
        if is_file_encrypted "$remote_file"; then
            local temp_decrypted=$(mktemp)
            decrypt_secrets_file "$remote_file" "$temp_decrypted"
            reencrypt_secrets "$temp_decrypted" "$SECRETS_FILE"
            rm -f "$temp_decrypted"
        else
            cp "$remote_file" "$SECRETS_FILE"
            chmod 600 "$SECRETS_FILE"
        fi
        
        rm -f "$remote_file"
        log "SUCCESS" "Synced secrets from $host (new file)"
        return 0
    fi
    
    # Decrypt both files for comparison
    local local_decrypted=$(mktemp)
    local remote_decrypted=$(mktemp)
    
    trap "rm -f $local_decrypted $remote_decrypted" EXIT
    
    decrypt_for_comparison "$SECRETS_FILE" "$local_decrypted" || {
        log "ERROR" "Cannot decrypt local secrets file"
        rm -f "$remote_file"
        return 1
    }
    
    decrypt_for_comparison "$remote_file" "$remote_decrypted" || {
        log "ERROR" "Cannot decrypt remote secrets file from $host"
        rm -f "$remote_file"
        return 1
    }
    
    # Compare versions (using decrypted files for metadata comparison)
    if ! $FORCE && ! is_newer "$remote_file" "$SECRETS_FILE"; then
        local local_version=$(get_file_version "$SECRETS_FILE")
        local remote_version=$(get_file_version "$remote_file")
        log "INFO" "Local version ($local_version) is same or newer than $host ($remote_version)"
        rm -f "$remote_file"
        return 0
    fi
    
    # Create backup
    create_backup "$SECRETS_FILE"
    
    # Use the remote decrypted content and re-encrypt to all recipients
    reencrypt_secrets "$remote_decrypted" "$SECRETS_FILE"
    
    rm -f "$remote_file"
    
    local remote_version=$(get_file_version "$SECRETS_FILE")
    local remote_host=$(get_file_host "$SECRETS_FILE")
    log "SUCCESS" "Synced secrets from $host (version $remote_version)"
    
    return 0
}

# Function to find the newest peer
find_newest_peer() {
    local newest_host=""
    local newest_file=""
    local newest_file_is_local=false

    if [[ -f "$SECRETS_FILE" ]]; then
        newest_file="$SECRETS_FILE"
        newest_file_is_local=true
    fi
    
    # Get list of peers
    local peers
    local discover_args=(--quiet)
    if ! $USE_HTTP; then
        discover_args+=(--ssh)
    fi
    if ! peers=$("$SCRIPT_DIR/env-sync-discover" "${discover_args[@]}"); then
        log "WARN" "No peers discovered"
        return 1
    fi
    
    # Check each peer
    while IFS= read -r peer; do
        [[ -z "$peer" ]] && continue
        
        # Skip self
        local my_hostname=$(get_hostname)
        if [[ "$peer" == "$my_hostname" ]]; then
            continue
        fi
        
        # Test connectivity
        if ! $USE_HTTP; then
            # In SCP mode, verify SSH works
            if ! test_ssh "$peer"; then
                log "DEBUG" "Cannot SSH to $peer (skipping)"
                continue
            fi
        fi
        
        # Fetch and check
        local remote_file
        if remote_file=$(fetch_from_host "$peer"); then
            if is_file_encrypted "$remote_file" && ! can_decrypt_file "$remote_file"; then
                log "DEBUG" "Cannot decrypt file from $peer (skipping)"
                rm -f "$remote_file"
                continue
            fi

            if [[ -z "$newest_file" ]] || is_newer "$remote_file" "$newest_file"; then
                newest_host="$peer"
                if [[ -n "$newest_file" && "$newest_file_is_local" == false ]]; then
                    rm -f "$newest_file"
                fi
                newest_file="$remote_file"
                newest_file_is_local=false
            else
                rm -f "$remote_file"
            fi
        fi
    done <<< "$peers"
    
    if [[ -z "$newest_host" ]]; then
        if [[ -n "$newest_file" && "$newest_file_is_local" == false ]]; then
            rm -f "$newest_file"
        fi
        if ! $USE_HTTP; then
            log "WARN" "No valid peers found via SSH"
            log "INFO" "Tip: Ensure SSH keys are set up between machines"
            log "INFO" "     Or use --insecure-http flag (not recommended)"
        fi
        return 1
    fi
    
    echo "$newest_host"
    if [[ -n "$newest_file" && "$newest_file_is_local" == false ]]; then
        rm -f "$newest_file"
    fi
}

# Main execution
maybe_reencrypt_local

if [[ -n "$TARGET_HOST" ]]; then
    # Sync from specific host
    if ! $USE_HTTP && ! test_ssh "$TARGET_HOST"; then
        log "ERROR" "Cannot SSH to $TARGET_HOST"
        log "INFO" "Ensure SSH keys are set up, or use --insecure-http flag"
        exit 1
    fi
    sync_from_host "$TARGET_HOST"
elif $ALL_PEERS; then
    # Sync from all peers (iterate and update)
    log "INFO" "Syncing from all discovered peers..."
    
    peers=""
    local discover_args=(--quiet)
    if ! $USE_HTTP; then
        discover_args+=(--ssh)
    fi
    if ! peers=$("$SCRIPT_DIR/env-sync-discover" "${discover_args[@]}"); then
        log "WARN" "No peers discovered"
        exit 1
    fi
    
    success_count=0
    while IFS= read -r peer; do
        [[ -z "$peer" ]] && continue
        
        # Skip self
        my_hostname=$(get_hostname)
        if [[ "$peer" == "$my_hostname" ]]; then
            continue
        fi
        
        # Test SSH connectivity in SCP mode
        if ! $USE_HTTP && ! test_ssh "$peer"; then
            continue
        fi
        
        if sync_from_host "$peer"; then
            ((success_count++))
        fi
    done <<< "$peers"
    
    if [[ $success_count -eq 0 ]]; then
        log "WARN" "Failed to sync from any peer"
        if ! $USE_HTTP; then
            log "INFO" "Tip: Set up SSH keys with: ssh-copy-id hostname.local"
        fi
        exit 1
    else
        log "SUCCESS" "Synced from $success_count peer(s)"
    fi
else
    # Auto mode: find newest peer and sync
    log "INFO" "Searching for newest secrets via $(if $USE_HTTP; then echo "HTTP"; else echo "SCP/SSH"; fi)..."
    
    newest_host=""
    if ! newest_host=$(find_newest_peer); then
        log "INFO" "No newer secrets found on network"
        if ! $USE_HTTP; then
            log "INFO" "To sync without SSH keys, use: env-sync --insecure-http"
        fi
        exit 0
    fi
    
    log "INFO" "Newest secrets found on: $newest_host"
    sync_from_host "$newest_host"
fi
