#!/bin/bash
# env-sync-client: Fetch and sync secrets from peers
# Usage: env-sync-client [options] [hostname]
# Options:
#   -a, --all          Sync from all discovered peers
#   -f, --force        Force sync even if local is newer
#   -q, --quiet        Quiet mode
#   hostname          Specific hostname to sync from (optional)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

ALL_PEERS=false
FORCE=false
TARGET_HOST=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -a|--all)
            ALL_PEERS=true
            shift
            ;;
        -f|--force)
            FORCE=true
            shift
            ;;
        -q|--quiet)
            ENV_SYNC_QUIET=true
            shift
            ;;
        -h|--help)
            echo "Usage: env-sync-client [options] [hostname]"
            echo "Options:"
            echo "  -a, --all          Sync from all discovered peers"
            echo "  -f, --force        Force sync even if local is newer"
            echo "  -q, --quiet        Quiet mode"
            echo "  hostname          Specific hostname to sync from"
            exit 0
            ;;
        -*)
            log "ERROR" "Unknown option: $1"
            exit 1
            ;;
        *)
            if [[ -z "$TARGET_HOST" ]]; then
                TARGET_HOST="$1"
            else
                log "ERROR" "Multiple hostnames specified"
                exit 1
            fi
            shift
            ;;
    esac
done

# Function to fetch from a single host
fetch_from_host() {
    local host="$1"
    local url="http://${host}:${ENV_SYNC_PORT}/secrets.env"
    local tmp_file=$(mktemp)
    
    log "INFO" "Fetching from $host..."
    
    # Fetch file with curl
    if ! curl -fsSL --connect-timeout 5 --max-time 10 "$url" -o "$tmp_file" 2>/dev/null; then
        log "WARN" "Failed to fetch from $host"
        rm -f "$tmp_file"
        return 1
    fi
    
    # Validate fetched file
    if ! validate_secrets_file "$tmp_file"; then
        log "WARN" "Invalid secrets file from $host"
        rm -f "$tmp_file"
        return 1
    fi
    
    echo "$tmp_file"
}

# Function to sync from a specific host
sync_from_host() {
    local host="$1"
    
    # Fetch file
    local remote_file
    if ! remote_file=$(fetch_from_host "$host"); then
        return 1
    fi
    
    # Check if local file exists
    if [[ ! -f "$SECRETS_FILE" ]]; then
        log "INFO" "No local secrets file found, copying from $host"
        cp "$remote_file" "$SECRETS_FILE"
        chmod 600 "$SECRETS_FILE"
        rm -f "$remote_file"
        log "SUCCESS" "Synced secrets from $host (new file)"
        return 0
    fi
    
    # Compare versions
    if ! $FORCE && ! is_newer "$remote_file" "$SECRETS_FILE"; then
        local local_version=$(get_file_version "$SECRETS_FILE")
        local remote_version=$(get_file_version "$remote_file")
        log "INFO" "Local version ($local_version) is same or newer than $host ($remote_version)"
        rm -f "$remote_file"
        return 0
    fi
    
    # Create backup
    create_backup "$SECRETS_FILE"
    
    # Copy remote file
    cp "$remote_file" "$SECRETS_FILE"
    chmod 600 "$SECRETS_FILE"
    rm -f "$remote_file"
    
    local remote_version=$(get_file_version "$SECRETS_FILE")
    local remote_host=$(get_file_host "$SECRETS_FILE")
    log "SUCCESS" "Synced secrets from $host (version $remote_version)"
    
    return 0
}

# Function to find the newest peer
find_newest_peer() {
    local newest_host=""
    local newest_file=""
    
    # Get list of peers
    local peers
    if ! peers=$("$SCRIPT_DIR/env-sync-discover" --quiet); then
        log "WARN" "No peers discovered"
        return 1
    fi
    
    # Check each peer
    while IFS= read -r peer; do
        [[ -z "$peer" ]] && continue
        
        # Skip self
        local my_hostname=$(get_hostname)
        if [[ "$peer" == "$my_hostname" ]]; then
            continue
        fi
        
        # Fetch and check
        local remote_file
        if remote_file=$(fetch_from_host "$peer"); then
            if [[ -z "$newest_file" ]] || is_newer "$remote_file" "$newest_file"; then
                newest_host="$peer"
                [[ -n "$newest_file" ]] && rm -f "$newest_file"
                newest_file="$remote_file"
            else
                rm -f "$remote_file"
            fi
        fi
    done <<< "$peers"
    
    if [[ -z "$newest_host" ]]; then
        log "WARN" "No valid peers found"
        return 1
    fi
    
    echo "$newest_host"
    [[ -n "$newest_file" ]] && rm -f "$newest_file"
}

# Main execution
if [[ -n "$TARGET_HOST" ]]; then
    # Sync from specific host
    sync_from_host "$TARGET_HOST"
elif $ALL_PEERS; then
    # Sync from all peers (iterate and update)
    log "INFO" "Syncing from all discovered peers..."
    
    local peers
    if ! peers=$("$SCRIPT_DIR/env-sync-discover" --quiet); then
        log "WARN" "No peers discovered"
        exit 1
    fi
    
    local success_count=0
    while IFS= read -r peer; do
        [[ -z "$peer" ]] && continue
        
        # Skip self
        local my_hostname=$(get_hostname)
        if [[ "$peer" == "$my_hostname" ]]; then
            continue
        fi
        
        if sync_from_host "$peer"; then
            ((success_count++))
        fi
    done <<< "$peers"
    
    if [[ $success_count -eq 0 ]]; then
        log "WARN" "Failed to sync from any peer"
        exit 1
    else
        log "SUCCESS" "Synced from $success_count peer(s)"
    fi
else
    # Auto mode: find newest peer and sync
    log "INFO" "Searching for newest secrets..."
    
    local newest_host
    if ! newest_host=$(find_newest_peer); then
        log "INFO" "No newer secrets found on network"
        exit 0
    fi
    
    log "INFO" "Newest secrets found on: $newest_host"
    sync_from_host "$newest_host"
fi
