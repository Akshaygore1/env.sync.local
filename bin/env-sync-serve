#!/bin/bash
# env-sync-serve: HTTP server for serving secrets file
# Usage: env-sync-serve [options]
# Options:
#   -p, --port PORT     Port to listen on (default: 5739)
#   -d, --daemon        Run as daemon
#   -q, --quiet         Quiet mode

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

PORT="$ENV_SYNC_PORT"
DAEMON=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -p|--port)
            PORT="$2"
            shift 2
            ;;
        -d|--daemon)
            DAEMON=true
            shift
            ;;
        -q|--quiet)
            ENV_SYNC_QUIET=true
            shift
            ;;
        -h|--help)
            echo "Usage: env-sync-serve [options]"
            echo "Options:"
            echo "  -p, --port PORT     Port to listen on (default: 5739)"
            echo "  -d, --daemon        Run as daemon"
            echo "  -q, --quiet         Quiet mode"
            exit 0
            ;;
        *)
            log "ERROR" "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Check if secrets file exists
if [[ ! -f "$SECRETS_FILE" ]]; then
    log "ERROR" "Secrets file not found: $SECRETS_FILE"
    log "INFO" "Run 'env-sync init' to create one"
    exit 1
fi

# Validate secrets file
if ! validate_secrets_file "$SECRETS_FILE"; then
    log "ERROR" "Invalid secrets file"
    exit 1
fi

# Function to handle HTTP request
handle_request() {
    local request
    read -r request
    
    # Extract method and path
    local method=$(echo "$request" | cut -d' ' -f1)
    local path=$(echo "$request" | cut -d' ' -f2)
    
    # Read headers
    local headers=""
    while IFS= read -r line; do
        line=$(echo "$line" | tr -d '\r')
        [[ -z "$line" ]] && break
        headers="$headers$line\n"
    done
    
    # Route handling
    case "$path" in
        "/health")
            local version=$(get_file_version "$SECRETS_FILE")
            local timestamp=$(get_file_timestamp "$SECRETS_FILE")
            local hostname=$(get_file_host "$SECRETS_FILE")
            local response="{\"status\": \"ok\", \"version\": \"$version\", \"timestamp\": \"$timestamp\", \"host\": \"$hostname\"}"
            
            echo -e "HTTP/1.1 200 OK\r"
            echo -e "Content-Type: application/json\r"
            echo -e "Content-Length: ${#response}\r"
            echo -e "\r"
            echo -e "$response"
            ;;
            
        "/secrets.env")
            if [[ "$method" != "GET" ]]; then
                echo -e "HTTP/1.1 405 Method Not Allowed\r"
                echo -e "\r"
                return
            fi
            
            local version=$(get_file_version "$SECRETS_FILE")
            local timestamp=$(get_file_timestamp "$SECRETS_FILE")
            local hostname=$(get_file_host "$SECRETS_FILE")
            local checksum=$(get_file_checksum "$SECRETS_FILE")
            local content=$(cat "$SECRETS_FILE")
            local length=${#content}
            
            echo -e "HTTP/1.1 200 OK\r"
            echo -e "Content-Type: text/plain\r"
            echo -e "Content-Length: $length\r"
            echo -e "X-EnvSync-Version: $version\r"
            echo -e "X-EnvSync-Timestamp: $timestamp\r"
            echo -e "X-EnvSync-Host: $hostname\r"
            echo -e "X-EnvSync-Checksum: $checksum\r"
            echo -e "\r"
            echo -e "$content"
            ;;
            
        *)
            echo -e "HTTP/1.1 404 Not Found\r"
            echo -e "Content-Type: text/plain\r"
            echo -e "\r"
            echo -e "Not Found"
            ;;
    esac
}

# Function to run server
run_server() {
    log "INFO" "Starting env-sync server on port $PORT"
    
    # Check if port is already in use
    if lsof -Pi :"$PORT" -sTCP:LISTEN -t >/dev/null 2>&1; then
        log "WARN" "Port $PORT is already in use"
        return 1
    fi
    
    # Create PID file
    local pid_file="$CONFIG_DIR/server.pid"
    mkdir -p "$CONFIG_DIR"
    echo $$ > "$pid_file"
    
    log "SUCCESS" "Server listening on http://0.0.0.0:$PORT"
    log "INFO" "Endpoints:"
    log "INFO" "  - GET /health       - Health check"
    log "INFO" "  - GET /secrets.env  - Get secrets file"
    
    # Start netcat server
    while true; do
        # Handle one request at a time
        if command -v nc >/dev/null 2>&1; then
            nc -l -p "$PORT" -c 'handle_request'
        else
            log "ERROR" "netcat (nc) is required but not installed"
            exit 1
        fi
    done
}

# Main execution
if [[ "$DAEMON" == true ]]; then
    # Run in background
    (
        exec 0<&-  # Close stdin
        exec 1>/dev/null  # Redirect stdout
        exec 2>/dev/null  # Redirect stderr
        cd /
        run_server
    ) &
    
    log "SUCCESS" "Server started in background (PID: $!)"
else
    # Run in foreground
    run_server
fi
